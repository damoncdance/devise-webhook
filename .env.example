# Airtable — get from airtable.com/account (Personal Access Token)
AIRTABLE_API_KEY=your_personal_access_token_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# OpenPhone — get from openphone.com → Settings → Webhooks → Secret
OPENPHONE_SECRET=your_openphone_webhook_secret_here

# Instantly — get from app.instantly.ai → Settings → Webhooks → Secret
INSTANTLY_SECRET=your_instantly_webhook_secret_here

# Instantly API — get from app.instantly.ai → Settings → API
INSTANTLY_API_KEY=your_instantly_api_key_here

# BatchData — two-token strategy
BATCHDATA_CONTACT=your_contact_token_here
BATCHDATA_FULL=your_full_token_here

# Chicago Data Portal
CHICAGO_DATA_TOKEN=your_chicago_data_portal_token_here
